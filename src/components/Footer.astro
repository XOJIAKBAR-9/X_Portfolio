---
import CallToAction from './CallToAction.astro'
import Logo from './Logo.astro'
import { Heading, Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'

/**
 * Footer Component
 *
 * @description A component that displays the footer of the website
 */
const currentYear = new Date().getFullYear()
---

<footer>
  <CallToAction />
  <section class="py-20">
    <Heading level="h2" class="sr-only">Footer</Heading>
    <div class="container grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
      <div class="flex flex-col gap-4">
        <Heading level="h3" size="h6">Navigation</Heading>
        <ul class="flex flex-col gap-2">
          <li><Link href="/">Home</Link></li>
          <li><Link href="/about">About</Link></li>
          <li><Link href="/portfolio">Portfolio</Link></li>
          <li><Link href="/contact">Contact</Link></li>
        </ul>
      </div>
      <div class="flex flex-col gap-4">
        <Heading level="h3" size="h6">My Projects</Heading>
        <ul class="flex flex-col gap-2">
          <li><Link href="/portfolio/workooo">Workooo</Link></li>
          <li><Link href="/portfolio/aqchabot">Aqchabot</Link></li>
          <li><Link href="/portfolio/weather-app">Weather App</Link></li>
          <li><Link href="/portfolio/arkanoid-game">Arkanoid Game</Link></li>
        </ul>
      </div>
      <div class="flex flex-col gap-4">
        <Heading level="h3" size="h6">Connect</Heading>
        <ul class="flex flex-col gap-2">
          <li>
            <Link isExternal href="https://github.com/XOJIAKBAR-9">
              <Icon aria-hidden="true" name="lucide:github" size={16} class="inline-block" />
              GitHub
            </Link>
          </li>
          <li>
            <Link isExternal href="https://www.linkedin.com/in/xojiakbar-akramov-9508a1332">
              <Icon aria-hidden="true" name="lucide:linkedin" size={16} class="inline-block" />
              LinkedIn
            </Link>
          </li>
          <li>
            <Link href="mailto:xojiakbaar9@gmail.com">
              <Icon aria-hidden="true" name="lucide:mail" size={16} class="inline-block" />
              xojiakbaar9@gmail.com
            </Link>
          </li>
        </ul>
      </div>
      <div class="flex flex-col gap-4">
        <Logo loading="lazy" />
        <p class="leading-[1.75]">
          Full-stack developer building web applications with Django, JavaScript, and AI. Based in Uzbekistan.
        </p>
      </div>
    </div>
  </section>
  <section class="py-8">
    <div class="container flex flex-col gap-4 md:flex-row md:justify-between">
      <p>
        &copy; {currentYear} Xojiakbar Akramov. Built with <Link href="https://astro.build/">Astro</Link>.
      </p>
      <p>
        Theme by <Link href="https://github.com/markteekman">Mark Teekman</Link>. Part of <Link
          href="https://www.incluud.dev">Incluud</Link
        >.
      </p>
    </div>
  </section>
</footer>

<style>
  section {
    border-top: 1px solid var(--border-color-subtle);
  }
</style>
